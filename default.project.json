{
  "name": "MegabloxGame",
  "tree": {
    "$className": "DataModel",

    "ReplicatedStorage": {
      "Events": {
        "$className": "Folder"
      },
      "Shared": {
        "$path": "src/shared"
      }
    },

    "ServerScriptService": {
      "Server": {
        "$path": "src/server"
      }
    },

    "ServerStorage": {
      "BonkHammer": {
        "$path": "src/tools/BonkHammer"
      }
    },

    "StarterPlayer": {
      "StarterPlayerScripts": {
        "Client": {
          "$path": "src/client"
        }
      }
    },

    "Workspace": {
      "$properties": {
        "FilteringEnabled": true
      },
      "Spawns": {
        "$className": "Folder"
      },
      "Arena": {
        "$className": "Folder"
      }
    },

    "Lighting": {
      "$properties": {
        "Ambient": [0.3, 0.3, 0.3],
        "Brightness": 2,
        "GlobalShadows": true,
        "Technology": "Voxel"
      }
    }
  }
}
