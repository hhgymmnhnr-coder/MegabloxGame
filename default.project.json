{
  "name": "MegabloxGame",
  "tree": {
    "$className": "DataModel",

    "ReplicatedStorage": {
      "Events": { "$className": "Folder" },
      "Shared": { "$path": "src/shared" }
    },

    "ServerScriptService": {
      "Server": { "$path": "src/server" }
    },

    "ServerStorage": {
      "BonkHammer": {
        "$className": "Tool",
        "$properties": {
          "ToolTip": "Bonk !",
          "GripPos": [0, -1.5, 0],
          "GripForward": [0, 0, -1],
          "GripUp": [0, 1, 0]
        },
        "Handle": {
          "$className": "Part",
          "$properties": {
            "Size": [0.8, 4, 0.8],
            "Color": [0.768, 0.157, 0.110],
            "Material": "SmoothPlastic",
            "Anchored": false
          }
        },
        "HammerScript": {
          "$path": "src/tools/BonkHammer/hammer.client.luau"
        }
      }
    },

    "StarterPlayer": {
      "StarterPlayerScripts": {
        "Client": { "$path": "src/client" }
      }
    },

    "Workspace": {
      "$properties": { "FilteringEnabled": true },
      "Spawns": { "$className": "Folder" },
      "Arena": { "$className": "Folder" },
      "LobbySpawn": {
        "$className": "SpawnLocation",
        "$properties": {
          "Size": [6, 1, 6],
          "Position": [0, 5, 0],
          "Anchored": true,
          "Enabled": true,
          "Transparency": 0.5
        }
      },
      "Floor": {
        "$className": "Part",
        "$properties": {
          "Size": [90, 8, 90],
          "Position": [0, 0, 0],
          "Anchored": true,
          "Color": [0.929, 0.835, 0.314]
        }
      }
    },

    "Lighting": {
      "$properties": {
        "Ambient": [0.3, 0.3, 0.3],
        "Brightness": 2,
        "GlobalShadows": true,
        "Technology": "Voxel"
      }
    }
  }
}
